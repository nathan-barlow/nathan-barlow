---
import { projects } from "../../scripts/projects";
import BaseLayout from "../../layouts/Layout.astro";
import SlideUp from "../../components/SlideUp.astro";
import Projects from "../../components/Projects.astro";
import TagsNav from "../../components/TagsNav.astro";

export async function getStaticPaths() {
    return projects.tags().map((tag: any) => ({
        params: { tag: projects.toSlug(tag) },
        props: { title: tag },
    }));
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
    <section>
        <SlideUp tag="h1" parts={title} />
        <TagsNav active={title} animate={false} />
        <Projects filters={{ tag: title }} />
    </section>
</BaseLayout>
