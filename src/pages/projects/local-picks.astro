        <div class="wp-block-group learned-card ui">
            <div
                class="wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained"
            >
                <div class="wp-block-group">
                    <div
                        class="wp-block-group__inner-container is-layout-constrained wp-block-group-is-layout-constrained"
