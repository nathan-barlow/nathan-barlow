export const metadata = {
    title: "Local Picks",
    description:
        "Inspired by growing up surrounded by farms and farmer's markets in Wisconsin, I sought out to create a resource that helps people find local products in their area. Local Picks is an online directory of farms, ranches, orchards, and more with advanced features like search with suggestions, ability to create, customize, and sponsor listings, and find listings on a Google Map.",
    date: "October 2024",
    order: 1,
    type: "Laravel",
    tags: ["Web App", "Custom Design", "Google Maps API"],
    url: "https://localpicks.org",
};
---

