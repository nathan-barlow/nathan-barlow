---
const { color = "currentColor", hoverColor = "currentColor" } = Astro.props;
---

<svg
    aria-hidden="true"
    class="arrow"
    width="10"
    height="10"
    viewBox="0 0 10 10"
    fill="none"
    stroke={color}
    stroke-width="2"
    stroke-linecap="round"
>
    <path class="line" d="M0 5h8"></path>
    <path class="tip" d="M5 1l4 4-4 4"></path>
</svg>

<style define:vars={{ color, hoverColor }}>
    .arrow {
        height: 1em;
        width: 1em;
        padding: 0.25em;
        flex-shrink: 0;
        stroke: var(--color);
        transition: stroke var(--transition);

        path {
            transition:
                opacity var(--transition),
                transform var(--transition);
        }

        path.line {
            opacity: 0;
        }

        path.tip {
            transform: translateX(-25%);
        }
    }

    :global(*:not(.card):hover),
    :global(*:not(.card):focus-within),
    :global(.card:has(.card-link:hover)),
    :global(.card:has(.card-link:focus-within)) {
        > .arrow {
            stroke: var(--hoverColor);

            path.line {
                opacity: 1;
            }

            path.tip {
                transform: none;
            }
        }
    }
</style>
