---
import Arrow from "./Arrow.astro";

const {
    href,
    variant = "default",
    size = "default",
    arrow = false,
    ...otherProps
} = Astro.props;

const classNames = ["button", `button--${variant}`];
if (arrow) classNames.push("button--arrow");
if (size) classNames.push("button--" + size);
---

<a class={classNames.join(" ")} href={href} {...otherProps}>
    <slot />
    {arrow && <Arrow />}
</a>

<style lang="scss">
    .button {
        --padding: 0.5em;

        padding: calc(var(--padding) + 2px);
        color: var(--color-primary);
        display: flex;
        align-items: center;
        gap: 0.5em;
        max-width: max-content;
        border-radius: 3px;
        transition:
            opacity var(--transition),
            transform 0.25s ease-out;

        &--small {
            --padding: 0.625em;
            font-size: 0.875rem;
        }

        &--arrow {
            padding-right: 0.25rem;
        }

        &:not(.button--arrow):hover {
            opacity: 0.9;
        }

        &:active {
            transform: scale(0.95);
        }

        &--minimal {
            padding: calc(var(--padding) + 2px) 0;
            background: none;
            color: var(--color-primary);
        }

        &--outline {
            padding: var(--padding);
            border: 1px solid var(--color-primary);
            color: var(--color-primary);
        }

        &--primary {
            color: var(--color-white);
            background-color: var(--color-primary);
            border-color: var(--color-primary);
        }
    }
</style>
