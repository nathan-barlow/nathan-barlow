---
import "../styles/global.scss";
import Header from "../layouts/Header.astro";
import Footer from "./Footer.astro";

const { title } = Astro.props;
const pageTitle = title ? title + " | Nate Barlow" : "Nate Barlow";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/favicon/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon/favicon-16x16.png"
        />
        <link rel="manifest" href="/favicon/site.webmanifest" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Albert+Sans:ital,wght@0,100..900;1,100..900&display=swap"
            rel="stylesheet"
        />

        <link
            href="https://fonts.googleapis.com/css2?family=Albert+Sans:ital,wght@0,100..900;1,100..900&family=Atkinson+Hyperlegible+Next:ital,wght@0,200..800;1,200..800&display=swap"
            rel="stylesheet"
        />

        <meta name="generator" content={Astro.generator} />

        <title>{pageTitle}</title>
    </head>
    <body>
        <Header />

        <main>
            <slot />
        </main>

        <Footer />
    </body>
</html>

<style lang="scss">
    :global(#pointer) {
        display: none;
    }

    @media screen and (hover: hover) {
        :global(#pointer) {
            --size: 30vw;
            border-radius: 100%;
            position: fixed;
            top: calc(var(--size) * -1 / 2);
            left: calc(var(--size) * -1 / 2);
            transform: translate(-50%, -50%) scale(0);
            z-index: -1;
            display: block;
            height: var(--size);
            width: var(--size);
            background-color: var(--color-primary-100);
            filter: blur(68px);
            opacity: 0;
            transform-origin: center;
            transition:
                transform 1s ease-out,
                opacity var(--transition);

            &.is-visible {
                opacity: 0.4;
                transform: translate(-50%, -50%) scale(1);
            }

            &::after {
                content: "";
                display: block;
                height: 100%;
                width: 100%;
                border-radius: inherit;
                background-color: var(--color-primary);
                transform: scale(0);
                transition: transform var(--transition);
            }
        }

        :global(.color-change #pointer) {
            &::after {
                transform: scale(1);
            }
        }
    }
</style>

<script is:inline>
    const STORAGE_KEY = "natebarlow_theme";
    const saved = localStorage.getItem(STORAGE_KEY);

    if (saved) {
        try {
            const config = JSON.parse(saved);
            if (config.colorScheme) {
                document.documentElement.style.colorScheme = config.colorScheme;
                document.body.classList.toggle("theme-" + config.colorScheme);
            }
            if (config.hue) {
                document.documentElement.style.setProperty(
                    "--primary-hue",
                    config.hue,
                );
            }
        } catch (e) {}
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.body.insertAdjacentHTML(
            "afterbegin",
            "<div id='pointer'></div>",
        );

        const blob = document.getElementById("pointer");

        if (!blob) return;

        let isInitialized = false;

        document.addEventListener("mousemove", (event) => {
            const x = event.clientX + "px";
            const y = event.clientY + "px";

            if (!isInitialized) {
                blob.classList.add("is-visible");
                isInitialized = true;
            }

            blob.style.left = x;
            blob.style.top = y;

            // blob.animate(
            //     { left: x, top: y },
            //     {
            //         duration: 1000,
            //         fill: "forwards",
            //         easing: "cubic-bezier(.8,0,.2,1)",
            //     },
            // );
        });
    });
</script>
